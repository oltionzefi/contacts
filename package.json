{
  "name": "contacts",
  "version": "0.1.1",
  "private": true,
  "dependencies": {
    "@fluentui/react": "^8.125.5",
    "@hookform/resolvers": "^5.2.2",
    "@types/jest": "^30.0.0",
    "exceljs": "^4.4.0",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.4",
    "react": "^19.2.4",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^7.14.0",
    "typescript": "^6.0.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "scripts": {
    "start": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "release": "release-it",
    "postcoverage": "node -e \"process.env.CI || require('child_process').execSync('open-cli coverage/lcov-report/index.html', {stdio:'inherit'})\"",
    "type-check": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o .dist",
    "format:check": "prettier --list-different \"src/**/*.{js,jsx,ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\"",
    "translations-scan": "i18next-scanner --config i18next-scanner.config.js",
    "serve:build": "vite build && vite preview",
    "build:wc": "tsc --noEmit && vite build --config vite.wc.config.ts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "plugin:react-hooks/recommended",
      "plugin:jsx-a11y/recommended"
    ],
    "plugins": [
      "react-hooks",
      "jsx-a11y"
    ]
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/react": "^10.3.4",
    "@storybook/react-vite": "^10.3.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "i18next-scanner": "^4.6.0",
    "i18next-scanner-typescript": "^1.0.6",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "open-cli": "^9.0.0",
    "prettier": "^3.8.1",
    "pretty-quick": "^4.2.2",
    "release-it": "^19.2.4",
    "storybook": "^10.3.4",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.6",
    "vitest": "^4.1.3"
  },
  "packageManager": "pnpm@10.33.0"
}